#!/bin/bash

# ─────────────────────────────────────────────
#  Ubuntu 24 Cloned VM Setup Script
#  Run this inside the VM (not Proxmox shell)
#  Usage: bash ubuntu24-vm-setup.sh
# ─────────────────────────────────────────────

# Intentionally no set -e — prevents mid-setup exits on non-critical errors

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

print_header() {
    echo ""
    echo -e "${BLUE}╔════════════════════════════════════════╗${NC}"
    echo -e "${BLUE}║   Ubuntu 24 Cloned VM Setup Script     ║${NC}"
    echo -e "${BLUE}╚════════════════════════════════════════╝${NC}"
    echo ""
}

print_step() {
    echo ""
    echo -e "${CYAN}${BOLD}▶ $1${NC}"
    echo -e "${CYAN}────────────────────────────────────────${NC}"
}

print_success() { echo -e "${GREEN}✔ $1${NC}"; }
print_warning() { echo -e "${YELLOW}⚠ $1${NC}"; }
print_error()   { echo -e "${RED}✘ $1${NC}"; }

# Fixed: redirect prompt to stderr so $() capture works correctly
ask() {
    echo -en "${BOLD}$1${NC} " >&2
    read -r REPLY
    echo "$REPLY"
}

confirm() {
    echo -en "${BOLD}$1 [y/N]: ${NC}"
    read -r REPLY
    [[ "$REPLY" =~ ^[Yy]$ ]]
}

validate_ip() {
    local ip=$1
    if [[ $ip =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]]; then
        IFS='.' read -ra PARTS <<< "$ip"
        for part in "${PARTS[@]}"; do
            if (( part > 255 )); then return 1; fi
        done
        return 0
    fi
    return 1
}

# ─── Sudo Check ────────────────────────────────

if ! sudo -v 2>/dev/null; then
    echo -e "${RED}✘ This script requires sudo privileges. Exiting.${NC}"
    exit 1
fi

# ─── Gather Info ───────────────────────────────

print_header

echo -e "${YELLOW}This script will configure your cloned Ubuntu 24 VM.${NC}"
echo -e "${YELLOW}Please have your desired hostname and IP ready.${NC}"
echo ""

# Warn if running over SSH
if [ -n "$SSH_CLIENT" ] || [ -n "$SSH_TTY" ]; then
    print_warning "You are connected via SSH."
    print_warning "If you change the IP, your SSH session will drop."
    print_warning "Reconnect to the new IP after reboot."
    echo ""
fi

CURRENT_HOSTNAME=$(hostname)
echo -e "Current hostname: ${RED}${CURRENT_HOSTNAME}${NC}"
NEW_HOSTNAME=$(ask "Enter new hostname:")

if [ -z "$NEW_HOSTNAME" ]; then
    print_error "Hostname cannot be empty. Exiting."
    exit 1
fi

echo ""
CURRENT_IP=$(hostname -I | awk '{print $1}')
echo -e "Current IP: ${RED}${CURRENT_IP}${NC}"

SET_STATIC=false
if confirm "Do you want to set a static IP?"; then
    SET_STATIC=true

    while true; do
        NEW_IP=$(ask "Enter new static IP (e.g. 10.1.1.50):")
        if validate_ip "$NEW_IP"; then break
        else print_error "Invalid IP address. Try again."; fi
    done

    while true; do
        SUBNET=$(ask "Enter subnet prefix (e.g. 24 for /24):")
        if [[ "$SUBNET" =~ ^[0-9]+$ ]] && (( SUBNET >= 1 && SUBNET <= 32 )); then break
        else print_error "Invalid subnet. Enter a number between 1-32."; fi
    done

    while true; do
        GATEWAY=$(ask "Enter gateway IP (e.g. 10.1.1.1):")
        if validate_ip "$GATEWAY"; then break
        else print_error "Invalid gateway IP. Try again."; fi
    done

    while true; do
        DNS=$(ask "Enter DNS server IP (e.g. 10.1.1.1):")
        if validate_ip "$DNS"; then break
        else print_error "Invalid DNS IP. Try again."; fi
    done

    echo ""
    print_warning "Detected netplan files:"
    sudo find /etc/netplan/ -name "*.yaml" | while read -r f; do echo "    $f"; done
    NETPLAN_FILE=$(sudo find /etc/netplan/ -name "*.yaml" | head -1)
    echo -e "  Will modify: ${CYAN}${NETPLAN_FILE}${NC}"
fi

# ─── Summary ───────────────────────────────────

echo ""
echo -e "${BOLD}Summary of changes:${NC}"
echo -e "  Hostname : ${RED}${CURRENT_HOSTNAME}${NC} → ${GREEN}${NEW_HOSTNAME}${NC}"
if [ "$SET_STATIC" = true ]; then
    echo -e "  IP       : ${RED}${CURRENT_IP}${NC} → ${GREEN}${NEW_IP}/${SUBNET}${NC}"
    echo -e "  Gateway  : ${GREEN}${GATEWAY}${NC}"
    echo -e "  DNS      : ${GREEN}${DNS}${NC}"
    echo -e "  Netplan  : ${GREEN}${NETPLAN_FILE}${NC}"
fi
echo ""

if ! confirm "Proceed with these settings?"; then
    echo "Aborted. No changes made."
    exit 0
fi

ERRORS=0

# ─── Step 1: Hostname ──────────────────────────

print_step "Step 1: Setting hostname"

if sudo hostnamectl set-hostname "$NEW_HOSTNAME"; then
    print_success "Hostname set to $NEW_HOSTNAME"
else
    print_error "Failed to set hostname"
    ((ERRORS++)) || true
fi

if sudo sed -i "s/127\.0\.1\.1.*/127.0.1.1\t${NEW_HOSTNAME}/" /etc/hosts; then
    if ! grep -q "127.0.1.1" /etc/hosts; then
        echo "127.0.1.1    ${NEW_HOSTNAME}" | sudo tee -a /etc/hosts > /dev/null
    fi
    print_success "/etc/hosts updated"
else
    print_error "Failed to update /etc/hosts"
    ((ERRORS++)) || true
fi

# ─── Step 2: Cloud-Init ────────────────────────

print_step "Step 2: Configuring cloud-init"

if [ -f /etc/cloud/cloud.cfg ]; then
    if grep -q "preserve_hostname" /etc/cloud/cloud.cfg; then
        sudo sed -i 's/preserve_hostname:.*/preserve_hostname: true/' /etc/cloud/cloud.cfg
    else
        echo "preserve_hostname: true" | sudo tee -a /etc/cloud/cloud.cfg > /dev/null
    fi
    print_success "preserve_hostname set to true"
else
    print_warning "cloud.cfg not found, skipping"
fi

# ─── Step 3: Static IP ─────────────────────────

if [ "$SET_STATIC" = true ]; then
    print_step "Step 3: Configuring static IP"

    if [ -z "$NETPLAN_FILE" ]; then
        NETPLAN_FILE="/etc/netplan/50-cloud-init.yaml"
        print_warning "No netplan file found, will create $NETPLAN_FILE"
    fi

    IFACE=$(ip -o link show | awk -F': ' '{print $2}' | grep -v lo | head -1)
    print_success "Detected network interface: $IFACE"

    sudo cp "$NETPLAN_FILE" "${NETPLAN_FILE}.bak"
    print_success "Backup saved: ${NETPLAN_FILE}.bak"

    sudo tee "$NETPLAN_FILE" > /dev/null <<EOF
network:
  version: 2
  ethernets:
    ${IFACE}:
      dhcp4: false
      addresses:
        - ${NEW_IP}/${SUBNET}
      routes:
        - to: default
          via: ${GATEWAY}
      nameservers:
        addresses:
          - ${DNS}
EOF

    print_success "Netplan config written"

    # Validate before applying
    if sudo netplan generate 2>/dev/null; then
        print_success "Netplan config validated OK"
        sudo netplan apply 2>/dev/null || print_warning "netplan apply had warnings (will fully apply on reboot)"
    else
        print_error "Netplan config has errors! Restoring backup..."
        sudo cp "${NETPLAN_FILE}.bak" "$NETPLAN_FILE"
        print_warning "Original netplan restored. IP was NOT changed."
        ((ERRORS++)) || true
    fi
fi

# ─── Step 4: Machine ID (right before reboot) ──

print_step "Step 4: Regenerating machine ID"

sudo truncate -s 0 /etc/machine-id
sudo rm -f /var/lib/dbus/machine-id
sudo dbus-uuidgen --ensure
print_success "Machine ID regenerated"

# ─── Done ──────────────────────────────────────

echo ""
if [ "$ERRORS" -gt 0 ]; then
    echo -e "${YELLOW}╔════════════════════════════════════════╗${NC}"
    echo -e "${YELLOW}║   Done — but $ERRORS step(s) had errors       ║${NC}"
    echo -e "${YELLOW}╚════════════════════════════════════════╝${NC}"
else
    echo -e "${GREEN}╔════════════════════════════════════════╗${NC}"
    echo -e "${GREEN}║           Setup Complete! ✔            ║${NC}"
    echo -e "${GREEN}╚════════════════════════════════════════╝${NC}"
fi

echo ""
echo -e "  Hostname : ${GREEN}${NEW_HOSTNAME}${NC}"
if [ "$SET_STATIC" = true ]; then
    echo -e "  New IP   : ${GREEN}${NEW_IP}${NC}"
    echo -e "  Gateway  : ${GREEN}${GATEWAY}${NC}"
    echo -e "  DNS      : ${GREEN}${DNS}${NC}"
    if [ -n "$SSH_CLIENT" ] || [ -n "$SSH_TTY" ]; then
        echo ""
        print_warning "SSH will drop. Reconnect to: ${NEW_IP}"
    fi
fi

echo ""
if confirm "Reboot now to apply all changes?"; then
    echo -e "${YELLOW}Rebooting in 5 seconds... Press Ctrl+C to cancel.${NC}"
    sleep 5
    sudo reboot
else
    print_warning "Remember to reboot manually: sudo reboot"
fi
