#!/bin/bash

# ─────────────────────────────────────────────
#  Docker + Portainer Install Script
#  Ubuntu 24 LTS
#  Usage: bash install-docker-portainer.sh
# ─────────────────────────────────────────────

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

print_header() {
    echo ""
    echo -e "${BLUE}╔════════════════════════════════════════╗${NC}"
    echo -e "${BLUE}║   Docker + Portainer Install Script    ║${NC}"
    echo -e "${BLUE}║   Ubuntu 24 LTS                        ║${NC}"
    echo -e "${BLUE}╚════════════════════════════════════════╝${NC}"
    echo ""
}

print_step()    { echo ""; echo -e "${CYAN}${BOLD}▶ $1${NC}"; echo -e "${CYAN}────────────────────────────────────────${NC}"; }
print_success() { echo -e "${GREEN}✔ $1${NC}"; }
print_warning() { echo -e "${YELLOW}⚠ $1${NC}"; }
print_error()   { echo -e "${RED}✘ $1${NC}"; }

confirm() {
    echo -en "${BOLD}$1 [y/N]: ${NC}"
    read -r REPLY
    [[ "$REPLY" =~ ^[Yy]$ ]]
}

bail_on_error() {
    if [ "$ERRORS" -gt 0 ]; then
        print_error "A critical error occurred. Cannot safely continue."
        print_error "Fix the error above and re-run the script."
        exit 1
    fi
}

# ─── Sudo Check ────────────────────────────────

if ! sudo -v 2>/dev/null; then
    echo -e "${RED}✘ This script requires sudo privileges. Exiting.${NC}"
    exit 1
fi

print_header

echo -e "${YELLOW}This script will install:${NC}"
echo -e "  • Docker Engine (latest)"
echo -e "  • Docker Compose plugin"
echo -e "  • Portainer CE (Community Edition)"
echo ""

if ! confirm "Ready to proceed?"; then
    echo "Aborted."
    exit 0
fi

ERRORS=0

# ─── Step 1: Update Package Lists ─────────────
# Note: Only refreshing package lists, not full upgrade
# Run 'sudo apt-get upgrade' separately at your own schedule

print_step "Step 1: Refreshing package lists"

if sudo apt-get update -qq; then
    print_success "Package lists updated"
else
    print_error "Package list update failed — check your internet connection"
    ((ERRORS++)) || true
fi

bail_on_error

# ─── Step 2: Install Dependencies ─────────────

print_step "Step 2: Installing dependencies"

# Note: lsb-release removed — not needed on Ubuntu 24, VERSION_CODENAME
# comes from /etc/os-release directly
if sudo apt-get install -y -qq \
    ca-certificates \
    curl \
    gnupg; then
    print_success "Dependencies installed"
else
    print_error "Failed to install dependencies"
    ((ERRORS++)) || true
fi

bail_on_error

# ─── Step 3: Add Docker GPG Key ───────────────

print_step "Step 3: Adding Docker GPG key"

sudo install -m 0755 -d /etc/apt/keyrings

if curl -fsSL https://download.docker.com/linux/ubuntu/gpg | \
    sudo gpg --dearmor -o /etc/apt/keyrings/docker.gpg; then
    sudo chmod a+r /etc/apt/keyrings/docker.gpg
    print_success "Docker GPG key added"
else
    print_error "Failed to add Docker GPG key"
    ((ERRORS++)) || true
fi

bail_on_error

# ─── Step 4: Add Docker Repository ────────────

print_step "Step 4: Adding Docker repository"

# Using /etc/os-release directly (lsb-release not needed on Ubuntu 24)
. /etc/os-release

if echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] \
https://download.docker.com/linux/ubuntu ${VERSION_CODENAME} stable" | \
    sudo tee /etc/apt/sources.list.d/docker.list > /dev/null; then
    sudo apt-get update -qq
    print_success "Docker repository added (Ubuntu ${VERSION_CODENAME})"
else
    print_error "Failed to add Docker repository"
    ((ERRORS++)) || true
fi

bail_on_error

# ─── Step 5: Install Docker ───────────────────

print_step "Step 5: Installing Docker Engine"

if sudo apt-get install -y -qq \
    docker-ce \
    docker-ce-cli \
    containerd.io \
    docker-buildx-plugin \
    docker-compose-plugin; then
    print_success "Docker Engine installed"
else
    print_error "Failed to install Docker Engine"
    ((ERRORS++)) || true
fi

bail_on_error

# ─── Step 6: Start & Enable Docker ────────────

print_step "Step 6: Starting Docker service"

if sudo systemctl enable docker --now; then
    print_success "Docker service enabled and started"
else
    print_error "Failed to start Docker service"
    ((ERRORS++)) || true
fi

# ─── Step 7: Add User to Docker Group ─────────

print_step "Step 7: Adding current user to docker group"

if sudo usermod -aG docker "$USER"; then
    print_success "User '$USER' added to docker group"
    print_warning "Log out and back in after install for this to take effect"
    print_warning "Until then the script uses 'sudo docker' automatically"
else
    print_error "Failed to add user to docker group"
    ((ERRORS++)) || true
fi

# ─── Step 8: Verify Docker ────────────────────

print_step "Step 8: Verifying Docker installation"

if sudo docker run --rm hello-world > /dev/null 2>&1; then
    DOCKER_VERSION=$(sudo docker --version)
    print_success "Docker is working — $DOCKER_VERSION"
else
    print_error "Docker test failed — something went wrong with the install"
    ((ERRORS++)) || true
fi

bail_on_error

# ─── Step 9: Install Portainer ────────────────

print_step "Step 9: Installing Portainer CE"

# Check if Portainer already exists
if sudo docker ps -a --format '{{.Names}}' | grep -q "^portainer$"; then
    print_warning "Portainer container already exists — skipping install"
    print_warning "To reinstall: sudo docker rm -f portainer && re-run this script"
else
    # Create volume
    if sudo docker volume create portainer_data > /dev/null; then
        print_success "Portainer data volume created"
    else
        print_error "Failed to create Portainer volume"
        ((ERRORS++)) || true
    fi

    # Run Portainer
    # Note: Port 8000 (Edge Agent) removed — not needed for basic standalone homelab
    # Add '-p 8000:8000' back if you plan to use Portainer Edge Agents
    if sudo docker run -d \
        --name portainer \
        --restart=always \
        -p 9443:9443 \
        -v /var/run/docker.sock:/var/run/docker.sock \
        -v portainer_data:/data \
        portainer/portainer-ce:latest > /dev/null; then
        print_success "Portainer container started"
    else
        print_error "Failed to start Portainer"
        ((ERRORS++)) || true
    fi
fi

# ─── Step 10: Check port 53 conflict ──────────

print_step "Step 10: Checking for port 53 conflicts (for DNS containers)"

# Using ss instead of lsof — ss is always available, lsof is not on Ubuntu minimal
PORT53=$(sudo ss -tulpn | grep ':53 ')
if [ -n "$PORT53" ]; then
    print_warning "Port 53 is in use — likely systemd-resolved"
    print_warning "This will block DNS containers like Technitium"
    echo ""
    if confirm "Disable systemd-resolved now to free port 53?"; then
        sudo systemctl disable systemd-resolved --now
        sudo rm -f /etc/resolv.conf
        # Write fallback DNS and make immutable to prevent Docker overwriting it
        echo "nameserver 8.8.8.8" | sudo tee /etc/resolv.conf > /dev/null
        sudo chattr +i /etc/resolv.conf
        print_success "systemd-resolved disabled, port 53 is now free"
        print_success "/etc/resolv.conf locked to prevent overwriting"
    else
        print_warning "Skipped — disable systemd-resolved before deploying DNS containers"
    fi
else
    print_success "Port 53 is free — no conflicts"
fi

# ─── Step 11: Check Firewall ──────────────────

print_step "Step 11: Checking firewall (ufw)"

if sudo ufw status 2>/dev/null | grep -q "Status: active"; then
    print_warning "ufw firewall is active — checking rules..."
    if ! sudo ufw status | grep -q "9443"; then
        print_warning "Port 9443 (Portainer) is not open in ufw"
        if confirm "Allow port 9443 in ufw now?"; then
            sudo ufw allow 9443/tcp > /dev/null
            print_success "Port 9443 allowed in ufw"
        fi
    else
        print_success "Port 9443 is already open in ufw"
    fi
else
    print_success "ufw is inactive — no firewall rules needed"
fi

# ─── Done ──────────────────────────────────────

HOST_IP=$(hostname -I | awk '{print $1}')

echo ""
if [ "$ERRORS" -gt 0 ]; then
    echo -e "${YELLOW}╔════════════════════════════════════════╗${NC}"
    echo -e "${YELLOW}║   Done — but $ERRORS step(s) had errors       ║${NC}"
    echo -e "${YELLOW}╚════════════════════════════════════════╝${NC}"
else
    echo -e "${GREEN}╔════════════════════════════════════════╗${NC}"
    echo -e "${GREEN}║     Docker + Portainer Installed! ✔    ║${NC}"
    echo -e "${GREEN}╚════════════════════════════════════════╝${NC}"
fi

echo ""
echo -e "${BOLD}Access Portainer at:${NC}"
echo -e "  ${CYAN}https://${HOST_IP}:9443${NC}"
echo ""
echo -e "${RED}╔════════════════════════════════════════╗${NC}"
echo -e "${RED}║  ⚠  IMPORTANT — DO THIS NOW  ⚠        ║${NC}"
echo -e "${RED}║                                        ║${NC}"
echo -e "${RED}║  Open Portainer and create your admin  ║${NC}"
echo -e "${RED}║  account within 5 MINUTES or it will  ║${NC}"
echo -e "${RED}║  time out and need a container restart ║${NC}"
echo -e "${RED}╚════════════════════════════════════════╝${NC}"
echo ""
echo -e "${YELLOW}⚠ Log out and back in for docker group to take effect${NC}"
echo ""
